<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme -->
    <style name="Theme.UTSAD" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/navy_primary</item>
        <item name="colorPrimaryVariant">@color/navy_dark</item>
        <item name="colorOnPrimary">@color/text_white</item>
        <item name="colorSecondary">@color/chart_awards</item>
        <item name="colorOnSecondary">@color/text_white</item>
        <item name="android:colorBackground">@color/bg_cream</item>
        <item name="android:windowBackground">@color/bg_cream</item>
        <item name="android:statusBarColor">@color/navy_dark</item>
        <item name="android:navigationBarColor">@color/bg_cream</item>
    </style>

    <!-- Splash Screen Theme: fullscreen navy background -->
    <style name="Theme.UTSAD.Splash" parent="Theme.UTSAD">
        <item name="android:windowBackground">@color/navy_primary</item>
        <item name="android:statusBarColor">@color/navy_primary</item>
        <item name="android:navigationBarColor">@color/navy_primary</item>
        <item name="android:windowFullscreen">false</item>
    </style>

    <!-- SplashScreen API Theme (Android 12+) -->
    <style name="Theme.UTSAD.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/navy_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.UTSAD.Splash</item>
    </style>

    <!-- Style: Base TextAppearance -->
    <style name="TextAppearance.UTSAD" parent="TextAppearance.MaterialComponents.Body1">
    </style>

    <!-- Style: Tombol Primer (navy, rounded) -->
    <style name="Widget.UTSAD.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/button_primary</item>
        <item name="android:textColor">@color/text_white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Style: Card Transaksi -->
    <style name="Widget.UTSAD.Card.Transaction" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/bg_white</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Style: Toggle Button (Income/Expenses) -->
    <style name="Widget.UTSAD.Toggle" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textSize">13sp</item>
        <item name="android:textAllCaps">true</item>
        <item name="cornerRadius">8dp</item>
        <item name="strokeWidth">0dp</item>
    </style>

    <!-- Style: Section Title -->
    <style name="TextAppearance.UTSAD.SectionTitle">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.1</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Style: Amount Display (besar, bold) -->
    <style name="TextAppearance.UTSAD.AmountLarge">
        <item name="android:textSize">32sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Style: Dropdown/Input Field -->
    <style name="Widget.UTSAD.InputField" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/navy_light</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/text_hint</item>
    </style>

</resources>