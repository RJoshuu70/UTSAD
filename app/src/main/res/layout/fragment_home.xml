<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <RelativeLayout
            android:id="@+id/layout_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/navy_primary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="40dp"
            android:paddingBottom="20dp">

            <!-- Placeholder foto profil (ImageView) -->
            <ImageView
                android:id="@+id/iv_profile_placeholder"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="@drawable/bg_circle_expense"
                android:contentDescription="Foto Profil"
                android:scaleType="centerCrop" />

            <!-- Tanggal di kanan -->
            <TextView
                android:id="@+id/tv_date_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="23 April\n2026"
                android:textColor="@color/text_white"
                android:textSize="14sp"
                android:gravity="end"
                android:lineSpacingMultiplier="1.2" />
        </RelativeLayout>

        <!-- Total Amount Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="24dp"
            android:paddingBottom="16dp"
            android:background="@color/bg_cream">

            <!-- Label Total Amount -->
            <TextView
                android:id="@+id/tv_label_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL AMOUNT"
                style="@style/TextAppearance.UTSAD.SectionTitle" />

            <!-- Nilai total saldo -->
            <TextView
                android:id="@+id/tv_total_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp. 820.000,00"
                style="@style/TextAppearance.UTSAD.AmountLarge"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Card Form: Toggle + Input -->
        <LinearLayout
            android:id="@+id/card_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_purple"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:padding="20dp">

            <!-- Toggle: Income/Expenses -->
            <LinearLayout
                android:id="@+id/layout_toggle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_field"
                android:padding="4dp">

                <Button
                    android:id="@+id/btn_income"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="INCOME"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:textColor="@color/text_secondary"
                    android:background="@drawable/bg_toggle_inactive"
                    android:fontFamily="sans-serif-medium" />

                <Button
                    android:id="@+id/btn_expenses"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="EXPENSES"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:textColor="@color/text_white"
                    android:background="@drawable/bg_toggle_active"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Dropdown: Category -->
            <RelativeLayout
                android:id="@+id/dropdown_category"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginTop="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:id="@+id/tv_category_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Category"
                    android:textColor="@color/text_hint"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_dropdown"
                    android:contentDescription="Dropdown" />
            </RelativeLayout>

            <!-- Input: Amount -->
            <RelativeLayout
                android:id="@+id/field_amount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginTop="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <EditText
                    android:id="@+id/et_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:hint="Amount"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:inputType="numberDecimal"
                    android:background="@null"
                    android:maxLines="1" />
            </RelativeLayout>

            <!-- Dropdown: Source -->
            <RelativeLayout
                android:id="@+id/dropdown_source"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginTop="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <TextView
                    android:id="@+id/tv_source_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Source"
                    android:textColor="@color/text_hint"
                    android:textSize="15sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_dropdown"
                    android:contentDescription="Dropdown" />
            </RelativeLayout>

            <!-- Tombol Save -->
            <Button
                android:id="@+id/btn_save_home"
                style="@style/Widget.UTSAD.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Save"
                android:layout_marginTop="16dp" />
        </LinearLayout>

        <!-- Transaksi Terbaru -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="16dp">

            <!-- Header: label + View All -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="Recent Transaction"
                    android:textColor="@color/navy_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_view_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="View All"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp" />
            </RelativeLayout>

            <!-- Transaksi Item 1: Food (Expense) -->
            <include layout="@layout/item_transaction_home"
                android:id="@+id/item_transaction_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp" />

            <!-- Transaksi Item 2: Transportation (Expense) -->
            <include layout="@layout/item_transaction_home"
                android:id="@+id/item_transaction_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Bottom padding agar tidak tertutup FAB -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="80dp" />
    </LinearLayout>

</androidx.core.widget.NestedScrollView>