<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_white"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ===================================================== -->
        <!-- Header: Logo + Tanggal                                 -->
        <!-- ===================================================== -->
        <RelativeLayout
            android:id="@+id/layout_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/sys_navy_500"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="40dp"
            android:paddingBottom="20dp">

            <!-- Logo / Placeholder foto profil -->
            <ImageView
                android:id="@+id/iv_profile_placeholder"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/logo_notext"
                android:contentDescription="Logo Aplikasi"
                android:scaleType="fitCenter" />

            <!-- Tanggal di kanan -->
            <TextView
                android:id="@+id/tv_date_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="23 April\n2026"
                android:textColor="@color/text_white"
                android:textSize="14sp"
                android:gravity="end"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.2" />
        </RelativeLayout>

        <!-- ===================================================== -->
        <!-- Total Amount Section                                   -->
        <!-- ===================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="28dp"
            android:paddingBottom="20dp"
            android:background="@color/bg_white">

            <!-- Label -->
            <TextView
                android:id="@+id/tv_label_total"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL AMOUNT"
                android:textColor="@color/sys_navy_900"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textStyle="bold" />

            <!-- Nilai Total Saldo -->
            <TextView
                android:id="@+id/tv_total_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp. 820.000,00"
                android:textColor="@color/sys_navy_900"
                android:textSize="32sp"
                android:textStyle="bold"
                android:layout_marginTop="6dp" />
        </LinearLayout>

        <!-- ===================================================== -->
        <!-- Card Form: Toggle (Income/Expenses) + Input Fields    -->
        <!-- ===================================================== -->
        <LinearLayout
            android:id="@+id/card_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card_purple"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:padding="20dp">

            <!-- Toggle: INCOME / EXPENSES -->
            <LinearLayout
                android:id="@+id/layout_toggle"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:orientation="horizontal"
                android:background="@drawable/bg_input_field"
                android:padding="4dp">

                <Button
                    android:id="@+id/btn_income"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="INCOME"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:textColor="@color/sys_navy_900"
                    android:background="@drawable/bg_toggle_inactive"
                    android:fontFamily="sans-serif-medium" />

                <Button
                    android:id="@+id/btn_expenses"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="EXPENSES"
                    android:textSize="12sp"
                    android:textAllCaps="true"
                    android:textColor="@color/text_white"
                    android:background="@drawable/bg_toggle_active"
                    android:fontFamily="sans-serif-medium" />
            </LinearLayout>

            <!-- Dropdown: Category (dengan chevron) -->
            <RelativeLayout
                android:id="@+id/dropdown_category"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginTop="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_category_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:text="Category"
                    android:textColor="@color/text_hint"
                    android:textSize="15sp" />

                <!-- Chevron icon -->
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_dropdown"
                    android:contentDescription="Pilih Kategori" />
            </RelativeLayout>

            <!-- Input: Amount (teks biasa, bukan dropdown) -->
            <RelativeLayout
                android:id="@+id/field_amount"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginTop="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <EditText
                    android:id="@+id/et_amount"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:hint="Amount"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:inputType="numberDecimal"
                    android:background="@null"
                    android:maxLines="1" />
            </RelativeLayout>

            <!-- Input: Source (teks biasa, bukan dropdown — sesuai Figma) -->
            <RelativeLayout
                android:id="@+id/field_source"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_field"
                android:layout_marginTop="12dp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <EditText
                    android:id="@+id/et_source"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:hint="Source"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:inputType="text"
                    android:background="@null"
                    android:maxLines="1" />
            </RelativeLayout>

            <!-- Tombol Save -->
            <Button
                android:id="@+id/btn_save_home"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Save"
                android:textColor="@color/text_white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:backgroundTint="@color/sys_navy_500"
                android:layout_marginTop="16dp"
                android:stateListAnimator="@null"
                app:cornerRadius="12dp" />
        </LinearLayout>

        <!-- ===================================================== -->
        <!-- Recent Transactions                                    -->
        <!-- ===================================================== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <!-- Header row: Label + View All -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="Recent Transaction"
                    android:textColor="@color/sys_navy_900"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_view_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="View All"
                    android:textColor="@color/sys_navy_500"
                    android:textSize="13sp" />
            </RelativeLayout>

            <!-- Item Transaksi 1 -->
            <include layout="@layout/item_transaction_home"
                android:id="@+id/item_transaction_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp" />

            <!-- Item Transaksi 2 -->
            <include layout="@layout/item_transaction_home"
                android:id="@+id/item_transaction_2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Bottom padding agar tidak tertutup Bottom Nav -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="80dp" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>