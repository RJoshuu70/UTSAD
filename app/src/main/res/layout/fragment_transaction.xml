<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_cream">

    <!-- Header: Navy Bar with Centered Title -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/sys_navy_500"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp">

        <TextView
            android:id="@+id/tv_title_transaction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="TRANSACTION"
            android:textColor="@color/text_white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />
    </RelativeLayout>

    <!-- Filters Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <!-- Filter bulan dan kategori -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Filter: Month -->
            <RelativeLayout
                android:id="@+id/btn_filter_month"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_filter_chip"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/iv_filter_month"
                    android:text="April, 2026"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/iv_filter_month"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_dropdown"
                    android:contentDescription="Filter bulan" />
            </RelativeLayout>

            <!-- Filter: All -->
            <RelativeLayout
                android:id="@+id/btn_filter_all"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_filter_chip"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/iv_filter_all"
                    android:text="All"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/iv_filter_all"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_dropdown"
                    android:contentDescription="Filter semua" />
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- List Transaksi -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Group: 22 April 2026 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="22 April 2026"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="8dp"
                android:layout_marginTop="4dp" />

            <!-- Item: Food (Expense) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_transaction_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <!-- Title (Top Left) -->
                <TextView
                    android:id="@+id/tv_trx1_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Food"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentStart="true" />

                <!-- More Button (Top Right) -->
                <ImageView
                    android:id="@+id/btn_more_1"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_more"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:contentDescription="More options"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Source with Indicator (Bottom Left) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_below="@id/tv_trx1_title"
                    android:layout_marginTop="8dp"
                    android:layout_alignParentStart="true">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_source_indicator"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cash"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Amount (Bottom Right) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-Rp20.000,00"
                    android:textColor="@color/expense_red"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:layout_below="@id/btn_more_1"
                    android:layout_marginTop="8dp" />
            </RelativeLayout>

            <!-- Item: Transportation (Expense) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_transaction_card"
                android:padding="16dp"
                android:layout_marginBottom="16dp">

                <!-- Title (Top Left) -->
                <TextView
                    android:id="@+id/tv_trx2_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Transportation"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentStart="true" />

                <!-- More Button (Top Right) -->
                <ImageView
                    android:id="@+id/btn_more_2"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_more"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:contentDescription="More options"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Source with Indicator (Bottom Left) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_below="@id/tv_trx2_title"
                    android:layout_marginTop="8dp"
                    android:layout_alignParentStart="true">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_source_indicator"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="E-Wallet"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Amount (Bottom Right) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-Rp10.000,00"
                    android:textColor="@color/expense_red"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:layout_below="@id/btn_more_2"
                    android:layout_marginTop="8dp" />
            </RelativeLayout>

            <!-- Group: 21 April 2026 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="21 April 2026"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginBottom="8dp" />

            <!-- Item: Food (Expense) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_transaction_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <!-- Title (Top Left) -->
                <TextView
                    android:id="@+id/tv_trx3_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Food"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentStart="true" />

                <!-- More Button (Top Right) -->
                <ImageView
                    android:id="@+id/btn_more_3"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_more"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:contentDescription="More options"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Source with Indicator (Bottom Left) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_below="@id/tv_trx3_title"
                    android:layout_marginTop="8dp"
                    android:layout_alignParentStart="true">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_source_indicator"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="E-Wallet"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Amount (Bottom Right) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-Rp50.000,00"
                    android:textColor="@color/expense_red"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:layout_below="@id/btn_more_3"
                    android:layout_marginTop="8dp" />
            </RelativeLayout>

            <!-- Item: Awards (Income) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_transaction_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <!-- Title (Top Left) -->
                <TextView
                    android:id="@+id/tv_trx4_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Awards"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentStart="true" />

                <!-- More Button (Top Right) -->
                <ImageView
                    android:id="@+id/btn_more_4"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_more"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:contentDescription="More options"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Source with Indicator (Bottom Left) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_below="@id/tv_trx4_title"
                    android:layout_marginTop="8dp"
                    android:layout_alignParentStart="true">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_source_indicator"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="E-Wallet"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Amount (Bottom Right) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+Rp500.000,00"
                    android:textColor="@color/income_green"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:layout_below="@id/btn_more_4"
                    android:layout_marginTop="8dp" />
            </RelativeLayout>

            <!-- Item: Salary (Income) -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_transaction_card"
                android:padding="16dp"
                android:layout_marginBottom="12dp">

                <!-- Title (Top Left) -->
                <TextView
                    android:id="@+id/tv_trx5_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Salary"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentStart="true" />

                <!-- More Button (Top Right) -->
                <ImageView
                    android:id="@+id/btn_more_5"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_more"
                    android:layout_alignParentTop="true"
                    android:layout_alignParentEnd="true"
                    android:contentDescription="More options"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Source with Indicator (Bottom Left) -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_below="@id/tv_trx5_title"
                    android:layout_marginTop="8dp"
                    android:layout_alignParentStart="true">

                    <View
                        android:layout_width="10dp"
                        android:layout_height="10dp"
                        android:background="@drawable/bg_source_indicator"
                        android:layout_marginEnd="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cash"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Amount (Bottom Right) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="+Rp400.000,00"
                    android:textColor="@color/income_green"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentBottom="true"
                    android:layout_below="@id/btn_more_5"
                    android:layout_marginTop="8dp" />
            </RelativeLayout>

            <!-- Bottom padding -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="80dp" />
        </LinearLayout>
    </ScrollView>
</LinearLayout>