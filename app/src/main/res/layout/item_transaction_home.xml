<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_transaction_card"
    android:padding="14dp">

    <!-- Baris atas: Nama Kategori (kiri) + Icon 3-dots (kanan) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/tv_category_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="Food"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <!-- Ikon 3 titik (kebab menu) -->
        <ImageView
            android:id="@+id/iv_more_home"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_more"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Opsi Transaksi" />
    </RelativeLayout>

    <!-- Baris bawah: Indikator warna + Sumber (kiri) + Jumlah (kanan) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp">

        <!-- Indikator kotak kecil berwarna + teks Sumber -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true">

            <!-- Kotak kecil warna sys_purple_200 (#A3B1E2) -->
            <View
                android:id="@+id/view_source_color"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/bg_source_indicator" />

            <!-- Nama Sumber Pembayaran (Cash / E-Wallet) -->
            <TextView
                android:id="@+id/tv_source"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cash"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginStart="6dp" />
        </LinearLayout>

        <!-- Jumlah transaksi (merah untuk expense, hijau untuk income) -->
        <TextView
            android:id="@+id/tv_amount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="-Rp20.000,00"
            android:textColor="@color/expense_red"
            android:textSize="13sp"
            android:textStyle="bold" />
    </RelativeLayout>

</LinearLayout>